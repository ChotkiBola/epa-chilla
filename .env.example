# Copy to .env.local for local development. In production these are set in
# Vercel → Project → Settings → Environment Variables.

# ---------------------------------------------------------------------------
# Password for /admin. This is the ONLY thing protecting the page, and the
# in-memory rate limit is per serverless instance, so it is a speed bump
# rather than a lockout. Use something long and random.
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# GitHub token used to commit config.json (and posters) from /admin.
# A commit is what triggers Vercel's redeploy — this is the whole persistence
# layer, so without it /admin can log in but cannot save.
#
# Create a fine-grained personal access token:
#   github.com → Settings → Developer settings
#     → Personal access tokens → Fine-grained tokens → Generate new token
#   Repository access : Only select repositories → this repo
#   Permissions       : Repository permissions → Contents → Read and write
#                       (that single permission is enough — nothing else)
#   Expiration        : set a reminder; the admin silently stops saving when
#                       it lapses.
# ---------------------------------------------------------------------------
GITHUB_TOKEN=

# owner/repository — e.g. epa-uz/epa-chilla
GITHUB_REPO=

# Branch Vercel deploys from.
GITHUB_BRANCH=main

# ---------------------------------------------------------------------------
# Bunny Stream (video hosting). Videos are uploaded and thumbnails picked in
# the Bunny panel; the site only lists the library for /admin and builds
# public CDN playback URLs.
#
#   BUNNY_LIBRARY_ID     — dash.bunny.net → Stream → your library → ID in the URL
#   BUNNY_STREAM_API_KEY — library → API → API Key  (SECRET — never commit it)
#   BUNNY_CDN_HOST       — library → API → CDN Hostname, e.g. vz-abc123-456.b-cdn.net
#
# Also enable in the library settings:
#   Player → MP4 Fallback  → ON  (gives play_720p.mp4 for very old browsers)
# All three empty = admin simply offers repo videos only.
# ---------------------------------------------------------------------------
BUNNY_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_CDN_HOST=
